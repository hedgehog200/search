<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Search Manager</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body class="light">
  <div class="backdrop">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
  </div>

  <header class="titlebar glass" id="dragZone">
    <div class="brand">
      <div class="brand-mark">⌕</div>
      <span>Search Manager</span>
    </div>
    <div class="title-actions">
      <button class="window-btn" data-window="minimize" aria-label="Свернуть">─</button>
      <button class="window-btn" data-window="maximize" aria-label="Развернуть">□</button>
      <button class="window-btn close" data-window="close" aria-label="Закрыть">×</button>
    </div>
  </header>

  <main class="app-shell">
    <aside class="dock glass-panel">
      <button class="dock-logo active" data-tab="dashboard" title="Панель">⌕</button>
      <button class="dock-btn" data-tab="setup" title="Настройка">◇</button>
      <button class="dock-btn" data-tab="results" title="Результаты">▦</button>
      <button class="dock-btn" data-tab="reports" title="Отчёты">▣</button>
      <button class="dock-btn" data-tab="settings" title="Настройки">⚙</button>
    </aside>

    <aside class="side glass-panel">
      <section class="profile">
        <div class="avatar">S</div>
        <div>
          <h2>Search Manager</h2>
          <p id="versionText">Готов к работе</p>
        </div>
      </section>

      <nav class="nav-block">
        <span class="nav-title">Разделы</span>
        <button class="nav-item active" data-tab="dashboard"><i>⌂</i><span>Главная</span><b id="badgeFound">0</b></button>
        <button class="nav-item" data-tab="setup"><i>◇</i><span>Настройка</span></button>
        <button class="nav-item" data-tab="results"><i>▦</i><span>Результаты</span><b id="badgeProcessed">0</b></button>
        <button class="nav-item" data-tab="reports"><i>▣</i><span>Отчёты</span></button>
      </nav>

      <section class="info-card">
        <span>Папка поиска</span>
        <strong id="searchPathMini">Не выбрана</strong>
      </section>

      <section class="info-card">
        <span>Папка отчётов</span>
        <strong id="savePathMini">По умолчанию</strong>
      </section>

      <section class="admin-card" id="adminCard">
        <div>
          <span id="adminState">Проверка прав...</span>
          <small>Для системных папок нужны права администратора</small>
        </div>
        <button id="adminBtn">Admin</button>
      </section>
    </aside>

    <section class="stage glass-main">
      <header class="hero">
        <div>
          <p class="eyebrow">Раздел <b id="floorName">Dashboard</b></p>
          <h1 id="pageTitle">Поиск файлов</h1>
          <p class="subtitle" id="pageSubtitle">Найдите файлы и папки по ключевым словам и сохраните отчёт.</p>
        </div>
        <div class="hero-actions">
          <label class="searchline glass-soft">
            <span>⌕</span>
            <input id="quickSearch" placeholder="Фильтр результатов" />
          </label>
          <button class="pill" id="themeToggle">Dark</button>
        </div>
      </header>

      <section class="content-scroll">
        <section class="tab-panel active" data-panel="dashboard">
          <div class="board dashboard-grid">
            <article class="panel-card primary-card">
              <div class="card-top"><span>Старт</span><b id="runState">Ready</b></div>
              <h2>Выберите папку и слова для поиска</h2>
              <p>Приложение проверит файлы и папки, покажет совпадения и сформирует отчёт.</p>
              <div class="action-row wrap">
                <button class="pill primary" id="chooseSearchBtn">Выбрать папку</button>
                <button class="pill" id="chooseSaveBtn">Папка отчёта</button>
              </div>
            </article>

            <article class="panel-card metric"><span>Найдено</span><strong id="metricFound">0</strong><small>совпадений</small></article>
            <article class="panel-card metric"><span>Обработано</span><strong id="metricProcessed">0</strong><small id="metricTotal">из 0</small></article>
            <article class="panel-card metric"><span>Пропущено</span><strong id="metricSkipped">0</strong><small>нет доступа</small></article>
          </div>

          <div class="board two-col">
            <article class="panel-card search-card">
              <h3>Ключевые слова</h3>
              <textarea id="wordsInput" placeholder="Например: отчёт договор проект\nМожно вводить через пробел, запятую или с новой строки"></textarea>
              <div class="chips" id="wordChips"></div>
            </article>

            <article class="panel-card control-card">
              <h3>Выполнение</h3>
              <div class="progress-row">
                <div class="ring" id="progressRing" style="--progress:0"><span id="progressText">0%</span></div>
                <div>
                  <p id="progressTitle">Готово к поиску</p>
                  <small id="progressSub">Выберите папку и ключевые слова</small>
                </div>
              </div>
              <div class="action-row wrap">
                <button class="pill primary" id="startBtn">Начать поиск</button>
                <button class="pill danger" id="cancelBtn">Отмена</button>
                <button class="pill" id="openReportBtn">Открыть отчёт</button>
              </div>
            </article>
          </div>
        </section>

        <section class="tab-panel" data-panel="setup">
          <div class="board two-col equal">
            <article class="panel-card">
              <h3>Папка для поиска</h3>
              <p class="muted">Программа рекурсивно проверит эту папку.</p>
              <div class="path-box" id="searchPathFull">Не выбрана</div>
              <button class="pill primary" id="chooseSearchBtn2">Выбрать папку поиска</button>
            </article>
            <article class="panel-card">
              <h3>Папка сохранения</h3>
              <p class="muted">Здесь будет создан txt-отчёт.</p>
              <div class="path-box" id="savePathFull">По умолчанию</div>
              <button class="pill" id="chooseSaveBtn2">Выбрать папку отчётов</button>
            </article>
          </div>
          <article class="panel-card wide-card">
            <h3>Параметры поиска</h3>
            <div class="settings-grid">
              <label class="toggle"><input type="checkbox" id="includeFiles" checked /> <span>Искать файлы</span></label>
              <label class="toggle"><input type="checkbox" id="includeFolders" checked /> <span>Искать папки</span></label>
              <label class="toggle"><input type="checkbox" id="openAfterSearch" checked /> <span>Предлагать открыть отчёт</span></label>
            </div>
          </article>
        </section>

        <section class="tab-panel" data-panel="results">
          <article class="panel-card results-card">
            <div class="card-toolbar">
              <h3>Результаты</h3>
              <span id="resultSummary">Нет данных</span>
            </div>
            <div class="table-wrap">
              <table id="resultsTable">
                <thead><tr><th>Тип</th><th>Имя</th><th>Ключ</th><th>Путь</th></tr></thead>
                <tbody><tr><td colspan="4">Запустите поиск, чтобы увидеть результаты.</td></tr></tbody>
              </table>
            </div>
          </article>
        </section>

        <section class="tab-panel" data-panel="reports">
          <div class="board two-col equal">
            <article class="panel-card">
              <h3>Последний отчёт</h3>
              <p class="muted" id="lastReportName">Отчёт ещё не создан</p>
              <div class="action-row wrap">
                <button class="pill primary" id="openReportBtn2">Открыть отчёт</button>
                <button class="pill" id="openReportFolderBtn">Открыть папку</button>
              </div>
            </article>
            <article class="panel-card">
              <h3>Статистика</h3>
              <div class="stats-list">
                <div><span>Время</span><b id="statDuration">—</b></div>
                <div><span>Найдено</span><b id="statFound">0</b></div>
                <div><span>Пропущено</span><b id="statSkipped">0</b></div>
              </div>
            </article>
          </div>
        </section>

        <section class="tab-panel" data-panel="settings">
          <article class="panel-card settings-card">
            <h3>Настройки интерфейса</h3>
            <label>Тема</label>
            <select id="themeSelect" class="field">
              <option value="light">Светлая</option>
              <option value="dark">Тёмная</option>
            </select>
            <label>Плотность интерфейса</label>
            <select id="densitySelect" class="field">
              <option value="comfortable">Обычная</option>
              <option value="compact">Компактная</option>
            </select>
            <p class="muted">Интерфейс сделан на WebView2: HTML, CSS и JavaScript внутри Windows-приложения.</p>
          </article>
        </section>
      </section>

      <footer class="log-dock glass-soft">
        <div class="log-head"><span>Журнал</span><button id="clearLogBtn">Очистить</button></div>
        <pre id="log"></pre>
      </footer>
    </section>
  </main>

  <div class="toast" id="toast"></div>
  <script src="app.js"></script>
</body>
</html>
